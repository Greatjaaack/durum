BOT_TOKEN=123
OWNER_ID=123
WORK_CHAT_ID=123
# Опционально: ID темы (topic) в супергруппе с форумом, куда слать отчёты.
# Если пусто — сообщения уходят в General. Узнать: в Telegram открой нужную тему,
# нажми «Поделиться ссылкой на сообщение» и возьми число после последнего «/».
WORK_CHAT_THREAD_ID=
DB_PATH=data/shifts.db
MEDIA_DIR=data/media
LOG_DIR=logs
BOT_TIMEZONE=Europe/Moscow
SHIFT_OPEN_TIME=11:00
SHIFT_CLOSE_TIME=22:00
# Опционально: прокси для Telegram API (пример)
# BOT_PROXY_URL=http://user:password@127.0.0.1:8080

# Авторизация дашборда (если оба поля заполнены — вход обязателен)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=password
DASHBOARD_SECRET=случайная_строка

# Xiaomi camera sync (опционально)
# Заполни camera_sync/.env — скрипт запускается автоматически каждый час
